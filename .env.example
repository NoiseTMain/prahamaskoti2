# === SUPABASE ===
# Najdete v Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# POZOR: service_role klíč nikdy nevystavujte na klientu, používá se pouze v API routách/serveru
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === E-MAILY (Resend) ===
# Vytvořte účet na https://resend.com a ověřte doménu
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Maskoti Praha <poptavky@maskotipraha.cz>"
EMAIL_ADMIN=info@maskotipraha.cz

# === RATE LIMITING (Upstash Redis) — volitelné, doporučené pro produkci ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === OBECNÉ ===
NEXT_PUBLIC_SITE_URL=https://www.maskotipraha.cz
